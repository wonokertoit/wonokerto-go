# Copy this file to .env.local and fill with your real values

# PostgreSQL database (Neon recommended)
DATABASE_URL='postgresql://user:password@host/db?sslmode=require'

# JWT session secret (generate random 32+ chars)
SESSION_SECRET='your-random-secret-key-here-min-32-chars'

# Resend API key (get from https://resend.com/api-keys)
RESEND_API_KEY='re_your_api_key_here'

# Sender email address
# Option A: Default Resend (no setup needed)
RESEND_FROM_EMAIL='onboarding@resend.dev'
# Option B: Your custom domain (must verify in Resend dashboard first)
# RESEND_FROM_EMAIL='admin@your-domain.com'
